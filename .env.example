# Database (Local Development)
DB_URL=jdbc:mysql://localhost:3306/sugang_helper?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
DB_DATABASE=sugang_helper
DB_USER=root
DB_PASSWORD=password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Redis (Local Development)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=password

# JWT
JWT_SECRET=
# 30min
JWT_ACCESS_EXPIRATION=1800000
# 14days
JWT_REFRESH_EXPIRATION=1209600000

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_REDIRECT_URI_SUCCESS=
OAUTH2_REDIRECT_URI_FAILURE=

# Firebase (FCM)
FIREBASE_CONFIG_PATH=./secrets/firebase-key.json

# Web Push (VAPID)
WEBPUSH_PUBLIC_KEY=
WEBPUSH_PRIVATE_KEY=
WEBPUSH_SUBJECT=mailto:admin@example.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Email Notification (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_AUTH=true
MAIL_STARTTLS_ENABLE=true

# Timezone
TZ=Asia/Seoul

# JBNU API (Real API URL - Keep this private)
JBNU_API_URL=

# Subscription
SUBSCRIPTION_MAX_LIMIT=3
