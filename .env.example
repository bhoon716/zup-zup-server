# Application
APP_IMAGE_NAME=sugang-helper
APP_CONTAINER_NAME=sugang-helper-app
APP_PORT_HOST=8080
APP_PORT_CONTAINER=8080

# Database
DB_IMAGE=mysql:8.0
DB_CONTAINER_NAME=sugang-helper-mysql
DB_URL=jdbc:mysql://db:3306/sugang_helper?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_DRIVER_CLASS_NAME=com.mysql.cj.jdbc.Driver
DB_PORT_HOST=3306
DB_PORT_CONTAINER=3306
DB_DATABASE=sugang_helper
DB_USER=root
DB_PASSWORD=password
DB_ROOT_PASSWORD=password
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# Redis
REDIS_IMAGE=redis:6-alpine
REDIS_CONTAINER_NAME=sugang-helper-redis
REDIS_HOST=redis
REDIS_PORT_HOST=6379
REDIS_PORT_CONTAINER=6379
REDIS_PASSWORD=password

# JWT
JWT_SECRET=
# 30min
JWT_ACCESS_EXPIRATION=1800000
# 14days
JWT_REFRESH_EXPIRATION=1209600000

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH2_REDIRECT_URI_SUCCESS=
OAUTH2_REDIRECT_URI_FAILURE=

# Firebase (FCM)
FIREBASE_CONFIG_PATH=src/main/resources/firebase/firebase-key.json

# Web Push (VAPID)
WEBPUSH_PUBLIC_KEY=
WEBPUSH_PRIVATE_KEY=
WEBPUSH_SUBJECT=mailto:admin@example.com

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Monitoring
PROMETHEUS_CONTAINER_NAME=sugang-helper-prometheus
PROMETHEUS_PORT_HOST=9090
PROMETHEUS_PORT_CONTAINER=9090
GRAFANA_CONTAINER_NAME=sugang-helper-grafana
GRAFANA_PORT_HOST=3000
GRAFANA_PORT_CONTAINER=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Email Notification (Gmail SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_AUTH=true
MAIL_STARTTLS_ENABLE=true

# Timezone
TZ=Asia/Seoul
